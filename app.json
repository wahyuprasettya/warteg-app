{
  "expo": {
    "name": "Kedai Tengger",
    "slug": "warteg-pos",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/app-icon/icon.png",
    "experiments": {
      "tsconfigPaths": true
    },
    "splash": {
      "image": "./assets/splashscreen/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#f3490e"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-icon/adaptive-icon.png",
        "backgroundColor": "#f3490e"
      }
    },
    "web": {
      "bundler": "metro"
    }
  }
}
