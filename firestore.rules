rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // Helper to get current user's profile data
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Helper to check if the user is authorized for a specific owner's data
    function isStaffOf(ownerId) {
      return signedIn() && (
        request.auth.uid == ownerId || 
        (getUserData().get('ownerId', '') == ownerId)
      );
    }

    // ==========================================
    // 🍔 QR MENU (Sisi Pelanggan - Public)
    // ==========================================

    match /menu/{menuId} {
      allow read: if true;
      allow write: if signedIn();
    }

    match /config/{configId} {
      allow read, write: if signedIn();
    }

    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if signedIn();
    }

    // ==========================================
    // 📱 POS ADMIN (Sisi Pemilik - Authenticated)
    // ==========================================

    match /users/{userId} {
      function ownsCashierDoc() {
        return signedIn() && resource.data.get('ownerId', '') == request.auth.uid;
      }

      allow create, delete: if signedIn() && (
        request.auth.uid == userId || ownsCashierDoc()
      );

      allow read: if isStaffOf(userId) || ownsCashierDoc();

      allow update: if signedIn() && (
        request.auth.uid == userId || 
        ownsCashierDoc() ||
        (getUserData().get('ownerId', '') == userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isStoreOpen', 'updatedAt']))
      );

      match /settings/{document=**} {
        allow read: if isStaffOf(userId);
        allow write: if signedIn() && request.auth.uid == userId;
      }
    }

    // --- TABLES (STATUS MEJA/BOOKING) ---
    match /tables/{tableDocId} {
      // ID dokumen format: [ownerId]-[tableId]
      allow write: if isStaffOf(tableDocId.split("-")[0]);
      allow read: if true;
    }

    match /transactions/{transactionId} {
      allow read, write: if signedIn();
    }

    match /closings/{closingId} {
      allow read, write: if signedIn();
    }
  }
}
